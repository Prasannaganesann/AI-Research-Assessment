# ==============================================================
# Autonomous Logistics Agent — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================

# ---- OpenAI (Closed-Source Model) ----------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ---- Groq (Open-Source Model via Groq Inference) -------------
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ---- Model Selection (fully configurable) --------------------
# Closed-source model identifier
CLOSED_SOURCE_MODEL=gpt-4o
# Open-source model identifier (via Groq)
OPEN_SOURCE_MODEL=qwen/qwen3-8b

# ---- Agent Behaviour -----------------------------------------
# Maximum retry attempts for tool calls
MAX_TOOL_RETRIES=3
# Seconds between retry attempts (exponential backoff base)
RETRY_BACKOFF_BASE=2
# Maximum steps the graph may execute before raising a halt error
MAX_GRAPH_STEPS=20

# ---- Evaluation ----------------------------------------------
# Number of test scenarios to run per model during benchmarking
EVAL_SCENARIOS=5
# Output directory for evaluation reports and figures
EVAL_OUTPUT_DIR=reports

# ---- Logging -------------------------------------------------
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Options: json | console  (json for production, console for dev)
LOG_FORMAT=console

# ---- Application ---------------------------------------------
APP_NAME=autonomous-logistics-agent
APP_VERSION=1.0.0
ENVIRONMENT=development
